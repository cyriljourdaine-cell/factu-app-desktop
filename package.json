{
  "name": "factu-app",
  "version": "1.6.7",
  "description": "Facturation - Jour And Light",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win --publish always"
  },
  "build": {
    "appId": "fr.jourandlight.factuapp",
    "productName": "factu.app",
    "publish": {
      "provider": "github",
      "owner": "cyriljourdaine-cell",
      "repo": "factu-app-desktop",
      "releaseType": "release"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "factu.app"
    },
    "files": [
      "src/**/*",
      "package.json"
    ]
  },
  "dependencies": {
    "electron-updater": "^6.1.0",
    "electron-log": "^5.0.0"
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.0.0"
  }
}